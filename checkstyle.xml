<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <property name="severity" value="warning"/>

    <!-- Nomes analitzar JocService -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="JocApp\.java$|JocMain\.java$"/>
    </module>

    <module name="TreeWalker">

        <!-- Noms descriptius (permet i,j,k per a bucles) -->
        <module name="LocalVariableName">
            <property name="format" value="^([ijk]|[a-z][a-zA-Z0-9]{2,})$"/>
            <message key="name.invalidPattern"
                value="Variable local ''{0}'' hauria de tenir un nom descriptiu (minim 3 caracters)."/>
        </module>
        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]{2,}$"/>
            <message key="name.invalidPattern"
                value="Parametre ''{0}'' hauria de tenir un nom descriptiu (minim 3 caracters)."/>
        </module>
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]{2,}$"/>
            <message key="name.invalidPattern"
                value="Atribut ''{0}'' hauria de tenir un nom descriptiu (minim 3 caracters)."/>
        </module>
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]{2,}$"/>
            <message key="name.invalidPattern"
                value="Metode ''{0}'' hauria de tenir un nom descriptiu (minim 3 caracters)."/>
        </module>

        <!-- Metodes curts -->
        <module name="MethodLength">
            <property name="max" value="15"/>
            <message key="maxLen.method"
                value="El metode te {0} linies (maxim recomanat: {1}). Considereu extract method."/>
        </module>

        <!-- Sense numeros magics -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1, 0, 1, 2, 3"/>
            <property name="ignoreAnnotation" value="true"/>
            <message key="magic.number"
                value="Numero magic ''{0}''. Useu una constant amb nom descriptiu."/>
        </module>

        <!-- Camps privats -->
        <module name="VisibilityModifier">
            <property name="allowPublicFinalFields" value="true"/>
            <message key="variable.notPrivate"
                value="L''atribut ''{0}'' hauria de ser privat. Useu getters si cal acces extern."/>
        </module>

        <!-- Complexitat ciclomatica -->
        <module name="CyclomaticComplexity">
            <property name="max" value="5"/>
            <message key="cyclomaticComplexity"
                value="Complexitat ciclomatica de {0} (maxim: {1}). Simplifiqueu el metode."/>
        </module>

    </module>
</module>
